# ─────────────────────────────────────────────
# ThermalWatch - Pi Configuration
# ─────────────────────────────────────────────

# IP address of the phone running phone_receiver.py
PHONE_IP=192.168.1.105

# UDP port to send frames on - must match phone/config.env
UDP_PORT=5000

# Temperature threshold in Celsius
# Frames with any pixel above this are sent to the phone
# A gas burner grate typically reads 150–300°C; 100°C gives a safe margin
TEMP_THRESHOLD=100

# Frames per second to sample from the camera
# 2fps is plenty - burners don't change state between frames
SAMPLE_FPS=2

# Error log file path - normal operation is always silent, only errors are written
# /tmp/thermalwatch.log  → RAM via tmpfs (no SD card writes, lost on reboot)
# /home/pi/thermalwatch/errors.log → persists across reboots (SD card, errors only)
LOG_FILE=/tmp/thermalwatch.log
