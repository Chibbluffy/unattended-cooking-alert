# ─────────────────────────────────────────────
# ThermalWatch - Phone Configuration
# ─────────────────────────────────────────────

# UDP port to listen on - must match pi/config.env
UDP_PORT=5000

# How many seconds of no person detected before alert fires
# 300 = 5 minutes
INACTIVITY_TIMEOUT=300

# Discord webhook URL - paste yours here after setting it up
# Server settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_HERE

# Human body temperature range in Celsius
# Pixels in this range are counted as potential person presence
# Adjust if environment causes false positives/negatives
PERSON_TEMP_MIN=28
PERSON_TEMP_MAX=40

# Minimum number of pixels in the human temp range to count as a person
# Raise this if warm objects cause false detections
# Lower this if your dad is far from the camera and appears small in frame
PERSON_MIN_PIXELS=30

# Script to run for audible alerts (default: alert.py in the same directory)
# Must accept an optional message as a command-line argument
# ALERT_SCRIPT=

# How often the verbal alarm repeats (seconds) while the stove is unattended
# The alarm stops as soon as someone comes into view
SPEAK_INTERVAL=30

# Minimum gap between repeated Discord messages (seconds)
# Verbal alarm still fires every SPEAK_INTERVAL regardless of this
ALERT_COOLDOWN=300

# Error log file path (optional - leave blank to log warnings to stderr)
# ~/thermalwatch/errors.log → persists across reboots
# LOG_FILE=
